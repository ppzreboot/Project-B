{
	"manifest_version": 3,
	"name": "PPz En Reader",
	"version": "0.0.0",
	"description": "选中网页文字后，用快捷键朗读英文",
	"permissions": ["storage"],
	"host_permissions": ["http://*/*", "https://*/*"],
	"icons": {
		"16": "icon/favicon-16x16.png",
		"32": "icon/favicon-32x32.png",
		"48": "icon/icon48.png",
		"128": "icon/icon128.png"
	},
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_title": "PPz En Reader"
	},
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["content.js"],
			"run_at": "document_idle"
		}
	],
	"commands": {
		"read-selection": {
			"suggested_key": {
				"default": "Ctrl+1",
				"mac": "Command+1"
			},
			"description": "朗读当前选中的文字"
		}
	},
	"options_ui": {
		"page": "options.html",
		"open_in_tab": true
	}
}
